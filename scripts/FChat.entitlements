<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened-runtime exceptions for the embedded interpreter + on-device ML.
         MLX/Metal JIT-compile kernels; the bundled relocatable CPython loads its
         own dylibs / .so extension modules (signed by us, not Apple) and is
         launched relocatably. Without these, hardened runtime would kill MLX or
         block Python from loading its libraries. The app is intentionally NOT
         sandboxed (it runs Python and reads user-picked files). -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>

    <!-- Read access to the user's Contacts for the (opt-in, read-only)
         contacts_search tool. Under the hardened runtime this resource-access
         entitlement is required to reach Contacts even though the app is not
         sandboxed; without it requestAccess() is denied (CNError 100) before
         the TCC prompt can appear. Pairs with NSContactsUsageDescription in
         Info.plist + the runtime CNContactStore.requestAccess prompt. -->
    <key>com.apple.security.personal-information.addressbook</key>
    <true/>

    <!-- Calendar access for the (opt-in) calendar tool. Same hardened-runtime
         requirement as addressbook above: without this entitlement EventKit's
         requestFullAccessToEvents() is denied before the TCC prompt can appear,
         even though the app is non-sandboxed. Pairs with
         NSCalendarsFullAccessUsageDescription in Info.plist. -->
    <key>com.apple.security.personal-information.calendars</key>
    <true/>
</dict>
</plist>
