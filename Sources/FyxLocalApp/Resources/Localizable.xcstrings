    "Maximum idle time between data packets before a request fails. Resets on each byte received, so long active replies are fine — this only catches a stalled connection. Raise it if a slow backend times out mid-reply.": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Maksimal inaktiv tid mellem datapakker, før en anmodning mislykkes. Nulstilles ved hver modtaget byte, så lange aktive svar er ingen problem — dette fanger kun en stoppet forbindelse. Øg den, hvis en langsom backend får timeout midt i et svar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Maximum idle time between data packets before a request fails. Resets on each byte received, so long active replies are fine — this only catches a stalled connection. Raise it if a slow backend times out mid-reply."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Maximum idle time between data packets before a request fails. Resets on each byte received, so long active replies are fine — this only catches a stalled connection. Raise it if a slow backend times out mid-reply."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Maksimal hviletid mellom datapakker før en forespørsel feiler. Nullstilles for hver mottatte byte, så lange aktive svar går fint — dette fanger kun en tilkobling som har stoppet opp. Øk den hvis en treg server får tidsavbrudd midt i svaret."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Maximal vilotid mellan datapaket innan en förfrågan misslyckas. Återställs vid varje mottagen byte, så långa aktiva svar är inga problem — detta fångar bara en stillastående anslutning. Höj den om en långsam backend gör time-out mitt i ett svar."
          }
        }
      }
    },
