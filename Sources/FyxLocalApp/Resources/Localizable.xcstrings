          }
        }
      }
    },
    "migration.v5.tcc.body": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalender, Påmindelser, Kontakter og Kort blev deaktiveret, fordi denne opdatering ændrede appens identitet, og macOS kræver, at du giver tilladelse igen. Aktivér dem igen i Indstillinger → Værktøjer, når du vil bruge dem, og godkend macOS-dialogen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendar, Reminders, Contacts and Maps were disabled because this update changed the app's identity, and macOS requires you to grant permission again. Re-enable them in Settings → Tools when you want them, and approve the macOS prompt."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Calendar, Reminders, Contacts and Maps were disabled because this update changed the app's identity, and macOS requires you to grant permission again. Re-enable them in Settings → Tools when you want them, and approve the macOS prompt."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalender, Påminnelser, Kontakter og Kart ble deaktivert fordi denne oppdateringen endret appens identitet, og macOS krever at du gir tillatelse på nytt. Aktiver dem igjen i Innstillinger → Verktøy når du vil bruke dem, og godkjenn macOS-forespørselen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kalender, Påminnelser, Kontakter och Kartor inaktiverades eftersom den här uppdateringen ändrade appens identitet, och macOS kräver att du ger åtkomst igen. Aktivera dem igen i Inställningar → Verktyg när du vill ha dem, och godkänn macOS-dialogen."
          }
        }
      }
    },
    "migration.v5.tcc.title": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple-værktøjer blev slået fra"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple tools were turned off"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple tools were turned off"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple-verktøy ble slått av"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple-verktyg stängdes av"
          }
        }
      }
    },
    "migration.v6.localnetwork.body": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fordi denne opdatering ændrede appens identitet, vil macOS igen bede om tilladelse til at finde enheder på dit lokale netværk, næste gang FyxLocal opretter forbindelse til en lokalt hostet model eller MCP-server. Klik på Tillad, når du bliver spurgt."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Because this update changed the app's identity, macOS will ask again for permission to find devices on your local network the next time FyxLocal connects to a locally-hosted model or MCP server. Click Allow when prompted."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Because this update changed the app's identity, macOS will ask again for permission to find devices on your local network the next time FyxLocal connects to a locally-hosted model or MCP server. Click Allow when prompted."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fordi denne oppdateringen endret appens identitet, vil macOS spørre på nytt om tillatelse til å finne enheter på lokalnettet neste gang FyxLocal kobler til en lokalt kjørende modell eller MCP-server. Klikk Tillat når du blir spurt."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Eftersom den här uppdateringen ändrade appens identitet kommer macOS att be om tillåtelse igen att hitta enheter i ditt lokala nätverk nästa gång FyxLocal ansluter till en lokalt körd modell eller MCP-server. Klicka på Tillåt när du tillfrågas."
          }
        }
      }
    },
    "migration.v6.localnetwork.title": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Adgang til lokalt netværk skal godkendes igen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local network access needs re-approving"
          }
        },
        "en-GB": {
