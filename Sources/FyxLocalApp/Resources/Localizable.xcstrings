    "%@ doesn't support tool calling — web search and other tools are off for its replies in this chat.": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ understøtter ikke værktøjskald — websøgning og andre værktøjer er slået fra for dens svar i denne chat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ doesn't support tool calling — web search and other tools are off for its replies in this chat."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ doesn't support tool calling — web search and other tools are off for its replies in this chat."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ støtter ikke verktøykall — nettsøk og andre verktøy er slått av for svarene dens i denne chatten."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ stöder inte verktygsanrop — webbsökning och andra verktyg är avstängda för dess svar i den här chatten."
          }
        }
      }
    },
