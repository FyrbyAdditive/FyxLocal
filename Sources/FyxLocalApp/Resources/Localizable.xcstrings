    "Skills are folders of instructions and scripts the model can use. Imported skills run in a sandbox with no network access. Enable a skill per-chat in the Inspector, or mark it as applying to every chat below.": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Færdigheder er mapper med instruktioner og scripts, som modellen kan bruge. Importerede færdigheder kører i en sandkasse uden netværksadgang. Aktivér en færdighed pr. chat i Inspektøren, eller markér, at den gælder for alle chats nedenfor."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skills are folders of instructions and scripts the model can use. Imported skills run in a sandbox with no network access. Enable a skill per-chat in the Inspector, or mark it as applying to every chat below."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Skills are folders of instructions and scripts the model can use. Imported skills run in a sandbox with no network access. Enable a skill per-chat in the Inspector, or mark it as applying to every chat below."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ferdigheter er mapper med instruksjoner og skript modellen kan bruke. Importerte ferdigheter kjører i en sandkasse uten nettverkstilgang. Aktiver en ferdighet per chat i Inspektøren, eller merk den som gjeldende for alle chatter nedenfor."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Färdigheter är mappar med instruktioner och skript som modellen kan använda. Importerade färdigheter körs i en sandlåda utan nätverksåtkomst. Aktivera en färdighet per chatt i inspektören, eller markera att den gäller alla chattar nedan."
          }
        }
      }
    },
