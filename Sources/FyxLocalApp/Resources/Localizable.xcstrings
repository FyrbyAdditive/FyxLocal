    "Runs an on-device model to re-order document-search results by relevance after keyword+vector retrieval. More relevant results; uses a little more memory and time per search.": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Kører en model på enheden for at omarrangere dokumentsøgningens resultater efter relevans, efter nøgleord- og vektorsøgning. Mere relevante resultater; bruger lidt mere hukommelse og tid pr. søgning."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs an on-device model to re-order document-search results by relevance after keyword+vector retrieval. More relevant results; uses a little more memory and time per search."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs an on-device model to re-order document-search results by relevance after keyword+vector retrieval. More relevant results; uses a little more memory and time per search."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Kjører en lokal modell som omsorterer dokumentsøkresultater etter relevans etter nøkkelord- og vektorgjenfinning. Mer relevante resultater; bruker litt mer minne og tid per søk."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kör en modell på enheten för att omordna dokumentsökningens resultat efter relevans, efter nyckelord- och vektorsökning. Mer relevanta resultat; använder lite mer minne och tid per sökning."
          }
        }
      }
    },
