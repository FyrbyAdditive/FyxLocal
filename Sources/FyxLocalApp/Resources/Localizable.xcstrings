      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple tools were turned off"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple tools were turned off"
          }
        },
        "sv": {
          "stringUnit": {
