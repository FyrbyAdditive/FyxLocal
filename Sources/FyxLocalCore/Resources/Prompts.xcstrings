{
  "sourceLanguage": "en",
  "strings": {
    "summarizer.prompt": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du sammenfatter den tidlige del af en igangværende samtale mellem en bruger og en assistent, så assistenten kan fortsætte samtalen i et nyt trin uden at se de tidligere beskeder direkte.\n\nBevar, i rækkefølge:\n1. Beslutninger, der er truffet, og konklusioner, der er nået.\n2. Navngivne enheder (personer, filer, URL'er, funktionsnavne, steder).\n3. Fakta, som brugeren har angivet som sande.\n4. Åbne spørgsmål eller opgaver, som brugeren endnu ikke har fået svar på.\n5. Værktøjer, der blev kaldt, og hovedindholdet af deres resultater.\n\nFjern smalltalk, gentaget kontekst, omstændelige forklaringer og trinvis ræsonnement. Skriv som en punktopstillet briefing i tredje person, ikke et referat. Sigt efter ca. 10-20 % af den oprindelige længde. Skriv kun selve sammenfatningen, uden indledning eller afslutning."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are summarizing the early portion of an ongoing conversation between a user and an assistant so that the assistant can continue the conversation in a new turn without seeing those earlier messages directly.\n\nPreserve, in order:\n1. Decisions made and conclusions reached.\n2. Named entities (people, files, URLs, function names, places).\n3. Facts the user stated as true.\n4. Open questions or tasks the user has not received an answer for yet.\n5. Tools that were invoked and the gist of their results.\n\nDrop chitchat, repeated context, verbose explanations, and step-by-step reasoning. Write as a third-person bulleted briefing, not a transcript. Target ~10–20% of original length. Output the summary text only, with no preamble or sign-off."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "You are summarizing the early portion of an ongoing conversation between a user and an assistant so that the assistant can continue the conversation in a new turn without seeing those earlier messages directly.\n\nPreserve, in order:\n1. Decisions made and conclusions reached.\n2. Named entities (people, files, URLs, function names, places).\n3. Facts the user stated as true.\n4. Open questions or tasks the user has not received an answer for yet.\n5. Tools that were invoked and the gist of their results.\n\nDrop chitchat, repeated context, verbose explanations, and step-by-step reasoning. Write as a third-person bulleted briefing, not a transcript. Target ~10–20% of original length. Output the summary text only, with no preamble or sign-off."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du oppsummerer den tidlige delen av en pågående samtale mellom en bruker og en assistent, slik at assistenten kan fortsette samtalen i en ny runde uten å se de tidligere meldingene direkte.\n\nBevar, i rekkefølge:\n1. Beslutninger som er tatt og konklusjoner som er nådd.\n2. Navngitte enheter (personer, filer, URL-er, funksjonsnavn, steder).\n3. Fakta brukeren har oppgitt som sanne.\n4. Åpne spørsmål eller oppgaver brukeren ennå ikke har fått svar på.\n5. Verktøy som ble brukt og essensen av resultatene deres.\n\nDropp småprat, gjentatt kontekst, ordrike forklaringer og trinnvis resonnering. Skriv som en punktvis orientering i tredjeperson, ikke som et referat. Sikt mot ~10–20 % av opprinnelig lengde. Skriv kun selve sammendraget, uten innledning eller avslutning."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du sammanfattar den tidiga delen av en pågående konversation mellan en användare och en assistent så att assistenten kan fortsätta konversationen i ett nytt steg utan att se de tidigare meddelandena direkt.\n\nBevara, i ordning:\n1. Beslut som fattats och slutsatser som dragits.\n2. Namngivna enheter (personer, filer, URL:er, funktionsnamn, platser).\n3. Fakta som användaren har angett som sanna.\n4. Öppna frågor eller uppgifter som användaren inte har fått svar på än.\n5. Verktyg som anropats och resultatet i korthet.\n\nTa bort småprat, upprepat sammanhang, utförliga förklaringar och stegvis resonemang. Skriv som en punktlista i tredje person, inte ett protokoll. Sikta på 10–20 % av originalets längd. Skriv endast själva sammanfattningen, utan inledning eller avslutning."
          }
        }
      }
    },
    "systemprompt.base": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du er FyxLocal, en hjælpsom macOS-assistent skabt af Fyrby Additive. Vær kortfattet, præcis og direkte. Svar på dansk, medmindre brugeren skriver på et andet sprog. Angiv kilder, når du bruger information fra websøgninger, hentede sider eller indekserede dokumenter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are FyxLocal, a helpful native macOS assistant created by Fyrby Additive. Be concise, accurate, and direct. Cite sources when you use information from web searches, fetched pages, or retrieved documents."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "You are FyxLocal, a helpful native macOS assistant created by Fyrby Additive. Be concise, accurate, and direct. Cite sources when you use information from web searches, fetched pages, or retrieved documents."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du er FyxLocal, en hjelpsom macOS-assistent laget av Fyrby Additive. Vær konsis, presis og direkte. Oppgi kilder når du bruker informasjon fra websøk, hentede sider eller gjenfunnede dokumenter."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du är FyxLocal, en hjälpsam macOS-assistent skapad av Fyrby Additive. Var kortfattad, korrekt och direkt. Svara på svenska om inte användaren skriver på ett annat språk. Ange källor när du använder information från webbsökningar, hämtade sidor eller indexerade dokument."
          }
        }
      }
    },
    "systemprompt.rag": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En eller flere dokumentsamlinger er knyttet til denne chat. Brug værktøjet `rag_search` til at slå information op, før du svarer på spørgsmål, der kan være dækket af det vedhæftede materiale, og angiv dokument og afsnit i dit svar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One or more document collections are attached to this chat. Use the `rag_search` tool to look up information before answering questions that might be covered by the attached material, and cite the document and section in your response."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "One or more document collections are attached to this chat. Use the `rag_search` tool to look up information before answering questions that might be covered by the attached material, and cite the document and section in your response."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Én eller flere dokumentsamlinger er knyttet til denne chatten. Bruk verktøyet `rag_search` til å slå opp informasjon før du svarer på spørsmål som kan være dekket av det vedlagte materialet, og oppgi dokument og avsnitt i svaret ditt."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En eller flera dokumentsamlingar är kopplade till denna chatt. Använd verktyget `rag_search` för att slå upp information innan du svarar på frågor som kan täckas av det bifogade materialet, och ange dokument och avsnitt i ditt svar."
          }
        }
      }
    },
    "systemprompt.tools": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du må bruge de tilgængelige værktøjer, når de hjælper dig med at svare. Foretræk færre velformede kald frem for mange små. Kald ikke et værktøj, hvis du allerede kender svaret."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You may call the provided tools when they help answer the user's question. Prefer fewer, well-formed calls over many small ones. Do not call a tool if you already have the answer."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "You may call the provided tools when they help answer the user's question. Prefer fewer, well-formed calls over many small ones. Do not call a tool if you already have the answer."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du kan kalle de tilgjengelige verktøyene når de hjelper deg å besvare brukerens spørsmål. Foretrekk få, velformede kall fremfor mange små. Ikke kall et verktøy hvis du allerede har svaret."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du får använda de tillgängliga verktygen när de hjälper dig att svara. Föredra färre välformulerade anrop framför många små. Anropa inte ett verktyg om du redan vet svaret."
          }
        }
      }
    },
    "temporal.dayheader": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "[I dag er %@; tidszone %@ (%@)]"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "[Today is %@; timezone %@ (%@)]"
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "[Today is %@; timezone %@ (%@)]"
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "[I dag er %@; tidssone %@ (%@)]"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "[Idag är %@; tidszon %@ (%@)]"
          }
        }
      }
    },
    "temporal.full": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Den aktuelle dato og tid er %@ (%@, %@). Maskinlæsbart: %@. Brug disse, når spørgsmålet afhænger af \"i dag\", \"nu\" eller hvor nyt noget er; stol ikke på din træningsdata til datofølsomme svar."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The current date and time is %@ (%@, %@). Machine-readable: %@. Use these when the question depends on \"today\", \"now\", or how recent something is; do not rely on your training cutoff for date-sensitive answers."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "The current date and time is %@ (%@, %@). Machine-readable: %@. Use these when the question depends on \"today\", \"now\", or how recent something is; do not rely on your training cutoff for date-sensitive answers."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Gjeldende dato og klokkeslett er %@ (%@, %@). Maskinlesbart: %@. Bruk disse når spørsmålet avhenger av «i dag», «nå» eller hvor nylig noe er; ikke stol på treningsdataene dine for datosensitive svar."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktuellt datum och tid är %@ (%@, %@). Maskinläsbart: %@. Använd dessa när frågan beror på \"idag\", \"nu\" eller hur färsk en händelse är; förlita dig inte på din träningsdata för datumkänsliga svar."
          }
        }
      }
    },
    "titler.prompt": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du skriver en kort titel til en chatsamtale. Se på brugerens første besked og assistentens første svar, og skriv derefter en titel på højst 6 ord og 60 tegn, der fanger emnet. Brug stort begyndelsesbogstav på hovedord. Ingen anførselstegn, ingen afsluttende tegnsætning, ingen indledning. Kun titlen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You write a short title for a chat conversation. Look at the user's first message and the assistant's first reply, then output a title of at most 6 words and 60 characters that captures the topic. Use title case. No quotes, no trailing punctuation, no preamble. Just the title."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "You write a short title for a chat conversation. Look at the user's first message and the assistant's first reply, then output a title of at most 6 words and 60 characters that captures the topic. Use title case. No quotes, no trailing punctuation, no preamble. Just the title."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du skriver en kort tittel for en chatsamtale. Se på brukerens første melding og assistentens første svar, og skriv en tittel på maks 6 ord og 60 tegn som fanger temaet. Bruk stor forbokstav på hovedord. Ingen anførselstegn, ingen avsluttende tegnsetting, ingen innledning. Bare tittelen."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du skriver en kort titel för en chattkonversation. Titta på användarens första meddelande och assistentens första svar, och skriv en titel på högst 6 ord och 60 tecken som fångar ämnet. Använd inledande versaler på huvudord. Inga citattecken, ingen avslutande interpunktion, ingen inledning. Bara titeln."
          }
        }
      }
    },
    "tool.calendar.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Læs brugerens macOS-kalender og (når brugeren har tilladt kalenderændringer) FORESLÅ at oprette, ændre eller slette begivenheder. `action`: \"search\" læser begivenheder (med det samme); \"create\"/\"edit\"/\"delete\" træder IKKE i kraft med det samme — de foreslås, og brugeren skal bekræfte hver ændring i appen først. Til edit/delete angives `event_id` for en begivenhed, du har fundet via søgning. VIGTIGT om datoer: dagens dato OG ugedag står i samtalen; når brugeren nævner en ugedag (\"tirsdag\") eller en relativ dag (\"i morgen\", \"i næste uge\"), så beregn den nøjagtige dato omhyggeligt ud fra i dag, og dobbelttjek at ugedagen passer, før du foreslår. Angiv `start`/`end` som `ÅÅÅÅ-MM-DDTHH:MM` (brugerens lokale tid)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read the user's macOS Calendar and (when the user has allowed calendar changes) PROPOSE creating, editing, or deleting events. `action`: \"search\" reads events (immediate); \"create\"/\"edit\"/\"delete\" do NOT take effect immediately — they are proposed and the user must confirm each change in the app before it happens. For edit/delete, pass the `event_id` of an event you found via search. IMPORTANT for dates: today's date AND weekday are given in the conversation; when the user names a weekday (\"Tuesday\") or a relative day (\"tomorrow\", \"next week\"), compute the exact calendar date carefully from today and double-check the weekday matches before proposing. Provide `start`/`end` as `YYYY-MM-DDTHH:MM` (the user's local time)."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Read the user's macOS Calendar and (when the user has allowed calendar changes) PROPOSE creating, editing, or deleting events. `action`: \"search\" reads events (immediate); \"create\"/\"edit\"/\"delete\" do NOT take effect immediately — they are proposed and the user must confirm each change in the app before it happens. For edit/delete, pass the `event_id` of an event you found via search. IMPORTANT for dates: today's date AND weekday are given in the conversation; when the user names a weekday (\"Tuesday\") or a relative day (\"tomorrow\", \"next week\"), compute the exact calendar date carefully from today and double-check the weekday matches before proposing. Provide `start`/`end` as `YYYY-MM-DDTHH:MM` (the user's local time)."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Les brukerens macOS-kalender og (når brukeren har tillatt kalenderendringer) FORESLÅ å opprette, redigere eller slette hendelser. `action`: \"search\" leser hendelser (umiddelbart); \"create\"/\"edit\"/\"delete\" trer IKKE i kraft umiddelbart — de foreslås, og brukeren må bekrefte hver endring i appen før den skjer. For edit/delete, send `event_id` for en hendelse du fant via search. VIKTIG om datoer: dagens dato OG ukedag er oppgitt i samtalen; når brukeren nevner en ukedag («tirsdag») eller en relativ dag («i morgen», «neste uke»), beregn den nøyaktige kalenderdatoen nøye fra i dag og dobbeltsjekk at ukedagen stemmer før du foreslår. Oppgi `start`/`end` som `YYYY-MM-DDTHH:MM` (brukerens lokale tid)."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Läs användarens macOS-kalender och (när användaren tillåtit kalenderändringar) FÖRESLÅ att skapa, ändra eller ta bort händelser. `action`: \"search\" läser händelser (omedelbart); \"create\"/\"edit\"/\"delete\" träder INTE i kraft direkt — de föreslås och användaren måste bekräfta varje ändring i appen först. För edit/delete, ange `event_id` för en händelse du hittat via sökning. VIKTIGT om datum: dagens datum OCH veckodag finns i konversationen; när användaren nämner en veckodag (\"tisdag\") eller en relativ dag (\"imorgon\", \"nästa vecka\"), beräkna det exakta datumet noggrant utifrån idag och dubbelkolla att veckodagen stämmer innan du föreslår. Ange `start`/`end` som `ÅÅÅÅ-MM-DDTHH:MM` (användarens lokala tid)."
          }
        }
      }
    },
    "tool.contacts.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skrivebeskyttet opslag i brugerens macOS-kontakter. Angiv `query` for at søge på navn, e-mail eller telefon; udelad den for at vise kontakter. Returnerer navn, organisation, e-mailadresser og telefonnumre. Værktøjet læser KUN kontakter — det tilføjer, ændrer eller sletter dem aldrig. Kræver, at brugeren har givet adgang til Kontakter."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read-only lookup of the user's macOS Contacts. Provide a `query` to search by name, email, or phone; omit it to list contacts. Returns name, organization, emails, and phone numbers. This tool ONLY reads contacts — it never adds, edits, or deletes them. Requires the user to have granted Contacts permission."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Read-only lookup of the user's macOS Contacts. Provide a `query` to search by name, email, or phone; omit it to list contacts. Returns name, organisation, emails, and phone numbers. This tool ONLY reads contacts — it never adds, edits, or deletes them. Requires the user to have granted Contacts permission."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Skrivebeskyttet oppslag i brukerens macOS-kontakter. Oppgi en `query` for å søke på navn, e-post eller telefon; utelat den for å liste kontakter. Returnerer navn, organisasjon, e-postadresser og telefonnumre. Dette verktøyet LESER kun kontakter — det legger aldri til, redigerer eller sletter dem. Krever at brukeren har gitt tilgang til Kontakter."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skrivskyddad uppslagning i användarens macOS-kontakter. Ange `query` för att söka på namn, e-post eller telefon; utelämna den för att lista kontakter. Returnerar namn, organisation, e-postadresser och telefonnummer. Verktyget ENDAST läser kontakter — det lägger aldrig till, ändrar eller tar bort dem. Kräver att användaren har gett behörighet till Kontakter."
          }
        }
      }
    },
    "tool.current_time.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Returnerer den aktuelle dato og tid med sekundpræcision i brugerens lokale tidszone (eller en navngiven IANA-zone, hvis angivet). Kald det, når svaret afhænger af det præcise klokkeslæt: planlægning, tid-siden-beregninger, hilsner som \"godmorgen\". Kald det ikke kun for at bekræfte datoen — datoen står allerede i hver brugerbesked."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Returns the current date and time at second precision in the user's local time zone (or a named IANA zone if provided). Call this when the answer depends on precise time of day: scheduling, time-since calculations, greetings like \"good morning\". Don't call it just to confirm the date — the date is already supplied in each user message."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Returns the current date and time at second precision in the user's local time zone (or a named IANA zone if provided). Call this when the answer depends on precise time of day: scheduling, time-since calculations, greetings like \"good morning\". Don't call it just to confirm the date — the date is already supplied in each user message."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Returnerer gjeldende dato og klokkeslett med sekundpresisjon i brukerens lokale tidssone (eller en navngitt IANA-sone hvis oppgitt). Kall dette når svaret avhenger av presist klokkeslett: planlegging, tid-siden-beregninger, hilsener som «god morgen». Ikke kall det bare for å bekrefte datoen — datoen følger allerede med i hver brukermelding."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Returnerar aktuellt datum och tid med sekundprecision i användarens lokala tidszon (eller en namngiven IANA-zon om sådan anges). Anropa när svaret beror på exakt klockslag: schemaläggning, tidssedan-beräkningar, hälsningar som \"god morgon\". Anropa inte bara för att bekräfta datumet — datumet finns redan med i varje användarmeddelande."
          }
        }
      }
    },
    "tool.make_chart.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tegn et lille diagram direkte i chatten. Understøttede typer: \"bar\", \"line\", \"pie\". Send et `series`-array med `{name, points}`; hvert punkt er `{x, y, label?}`. `x` kan være en streng (kategorisk akse) eller et tal (kontinuerlig akse) — bland ikke i samme diagram. `y` er altid et tal. Valgfrie topfelter: `title`, `xLabel`, `yLabel` (de sidste ignoreres for cirkeldiagrammer). Til cirkeldiagrammer bruges én serie, hvor hvert punkts `x` bliver lagkagestykkets etiket og `y` dets størrelse. Brug værktøjet, når brugeren beder om en graf, et diagram, eller når en visuel sammenligning er meget tydeligere end en tabel."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Render a small chart inline in the chat. Supported types: \"bar\", \"line\", \"pie\". Provide a `series` array of `{name, points}`; each point is `{x, y, label?}`. `x` can be a string (categorical axis) or a number (continuous axis); mix-and-match isn't supported — pick one per chart. `y` is always a number. Optional top-level fields: `title`, `xLabel`, `yLabel` (xLabel/yLabel are ignored for pies). For pie charts use one series; each point's `x` becomes the slice label and `y` its size. Use this when the user asks for a chart, a \"graph\", or when a visual comparison would be much clearer than a table."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Render a small chart inline in the chat. Supported types: \"bar\", \"line\", \"pie\". Provide a `series` array of `{name, points}`; each point is `{x, y, label?}`. `x` can be a string (categorical axis) or a number (continuous axis); mix-and-match isn't supported — pick one per chart. `y` is always a number. Optional top-level fields: `title`, `xLabel`, `yLabel` (xLabel/yLabel are ignored for pies). For pie charts use one series; each point's `x` becomes the slice label and `y` its size. Use this when the user asks for a chart, a \"graph\", or when a visual comparison would be much clearer than a table."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Tegn et lite diagram direkte i chatten. Støttede typer: \"bar\", \"line\", \"pie\". Oppgi en `series`-liste med `{name, points}`; hvert punkt er `{x, y, label?}`. `x` kan være en streng (kategorisk akse) eller et tall (kontinuerlig akse); blanding støttes ikke — velg én per diagram. `y` er alltid et tall. Valgfrie toppnivåfelt: `title`, `xLabel`, `yLabel` (xLabel/yLabel ignoreres for kakediagrammer). For kakediagram, bruk én serie; hvert punkts `x` blir etiketten til kakestykket og `y` størrelsen. Bruk dette når brukeren ber om et diagram, en «graf», eller når en visuell sammenligning er mye klarere enn en tabell."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Rita ett litet diagram direkt i chatten. Stödda typer: \"bar\", \"line\", \"pie\". Skicka en `series`-array med `{name, points}`; varje punkt är `{x, y, label?}`. `x` kan vara en sträng (kategorisk axel) eller ett tal (kontinuerlig axel) — blanda inte i samma diagram. `y` är alltid ett tal. Valfria toppfält: `title`, `xLabel`, `yLabel` (de senare ignoreras för pajdiagram). För pajdiagram, använd en serie där varje punkts `x` blir tårtbitens etikett och `y` dess storlek. Använd verktyget när användaren ber om en graf, ett diagram eller när en visuell jämförelse är mycket tydligare än en tabell."
          }
        }
      }
    },
    "tool.maps.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Søg i Apple Kort. VIGTIGT: hvert resultat fra dette værktøj vises OGSÅ for brugeren som et interaktivt kort (med nåle, og en rute ved vejvisning) direkte i chatten — så du behøver IKKE at angive rå koordinater eller gentage hver adresse; henvis til kortet (f.eks. \"jeg har vist dem på kortet nedenfor\") og sammenfat det vigtigste (navn, afstand, rejsetid). `action`: \"locate\" besvarer \"hvor er jeg?\" med enhedens placering (omvendt geokodet til sted/område); \"search\" finder steder/POI'er via naturligt sprog i `query` (f.eks. \"kaffe\", \"apotek\"); \"directions\" beregner en rute + rejsetid mellem `from` og `to`; \"geocode\" oversætter en adresse til koordinater; \"reverse_geocode\" oversætter `lat`/`lon` til en adresse. For \"i nærheden af mig\" sættes `near` til \"me\" — dette bruger enhedens placering, HVIS brugeren har tilladt det; ellers søger værktøjet uden placeringsbias, så foretræk at spørge brugeren om et sted/område, når placering har betydning. Brug \"locate\" først, når brugeren spørger, hvor de er, eller hvad der er i nærheden, og du endnu ikke kender deres område. Når brugeren vil have det NÆRMESTE af noget, så brug en GENERISK kategori i `query` (f.eks. \"tankstation\", \"apotek\") med `near`:\"me\" — søg IKKE på et bestemt mærke/firmanavn, medmindre brugeren nævner et, og resultaterne returneres nærmeste først. `from`/`to` til ruter kan være stednavne eller adresser (værktøjet slår dem op). `transport`: automobile (standard), walking eller transit."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search Apple Maps. IMPORTANT: every result from this tool is ALSO shown to the user as an interactive map (with pins, and a route for directions) rendered inline in the chat — so you do NOT need to list raw coordinates or restate every address; refer to the map (e.g. \"I've shown them on the map below\") and summarise the key facts (name, distance, ETA). `action`: \"locate\" answers \"where am I?\" using the device location (reverse-geocoded to a place/area); \"search\" finds places/POIs by natural-language `query` (e.g. \"coffee\", \"pharmacy\"); \"directions\" computes a route + ETA between `from` and `to`; \"geocode\" resolves an address to coordinates; \"reverse_geocode\" resolves `lat`/`lon` to an address. For \"near me\" set `near` to \"me\" — this uses the device location IF the user has allowed it; if not, the tool searches without a location bias, so prefer asking the user for a place/area when location matters. Use \"locate\" first when the user asks where they are or what's nearby and you don't yet know their area. When the user wants the NEAREST something, use a GENERIC category in `query` (e.g. \"petrol station\", \"gas station\", \"pharmacy\") with `near`:\"me\" — do NOT search a specific brand/company name unless the user named one, and results are returned nearest-first. `from`/`to` for directions may be place names or addresses (the tool resolves them). `transport`: automobile (default), walking, or transit."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Search Apple Maps. IMPORTANT: every result from this tool is ALSO shown to the user as an interactive map (with pins, and a route for directions) rendered inline in the chat — so you do NOT need to list raw coordinates or restate every address; refer to the map (e.g. \"I've shown them on the map below\") and summarise the key facts (name, distance, ETA). `action`: \"locate\" answers \"where am I?\" using the device location (reverse-geocoded to a place/area); \"search\" finds places/POIs by natural-language `query` (e.g. \"coffee\", \"pharmacy\"); \"directions\" computes a route + ETA between `from` and `to`; \"geocode\" resolves an address to coordinates; \"reverse_geocode\" resolves `lat`/`lon` to an address. For \"near me\" set `near` to \"me\" — this uses the device location IF the user has allowed it; if not, the tool searches without a location bias, so prefer asking the user for a place/area when location matters. Use \"locate\" first when the user asks where they are or what's nearby and you don't yet know their area. When the user wants the NEAREST something, use a GENERIC category in `query` (e.g. \"petrol station\", \"gas station\", \"pharmacy\") with `near`:\"me\" — do NOT search a specific brand/company name unless the user named one, and results are returned nearest-first. `from`/`to` for directions may be place names or addresses (the tool resolves them). `transport`: automobile (default), walking, or transit."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Søk i Apple Maps. VIKTIG: hvert resultat fra dette verktøyet vises OGSÅ for brukeren som et interaktivt kart (med nåler, og en rute for veibeskrivelser) direkte i chatten — så du trenger IKKE å liste rå koordinater eller gjenta hver adresse; vis til kartet (f.eks. «Jeg har vist dem på kartet nedenfor») og oppsummer nøkkelfakta (navn, avstand, ankomsttid). `action`: \"locate\" besvarer «hvor er jeg?» ved hjelp av enhetens posisjon (omvendt geokodet til et sted/område); \"search\" finner steder/interessepunkter med naturlig språk i `query` (f.eks. «kaffe», «apotek»); \"directions\" beregner en rute + ankomsttid mellom `from` og `to`; \"geocode\" gjør en adresse om til koordinater; \"reverse_geocode\" gjør `lat`/`lon` om til en adresse. For «i nærheten» sett `near` til \"me\" — dette bruker enhetens posisjon HVIS brukeren har tillatt det; hvis ikke, søker verktøyet uten posisjonspreferanse, så spør heller brukeren om et sted/område når posisjon er viktig. Bruk \"locate\" først når brukeren spør hvor de er eller hva som finnes i nærheten og du ennå ikke kjenner området. Når brukeren vil ha det NÆRMESTE av noe, bruk en GENERISK kategori i `query` (f.eks. «bensinstasjon», «apotek») med `near`:\"me\" — IKKE søk på et spesifikt merke-/firmanavn med mindre brukeren nevnte ett, og resultatene returneres nærmest først. `from`/`to` for veibeskrivelser kan være stedsnavn eller adresser (verktøyet løser dem opp). `transport`: automobile (standard), walking eller transit."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sök i Apple Kartor. VIKTIGT: varje resultat från detta verktyg visas OCKSÅ för användaren som en interaktiv karta (med nålar, och en rutt för vägbeskrivningar) direkt i chatten — så du behöver INTE lista råa koordinater eller upprepa varje adress; hänvisa till kartan (t.ex. \"jag har visat dem på kartan nedan\") och sammanfatta det viktigaste (namn, avstånd, restid). `action`: \"locate\" svarar på \"var är jag?\" med enhetens plats (omvänt geokodad till plats/område); \"search\" hittar platser via naturligt språk i `query` (t.ex. \"kaffe\", \"apotek\"); \"directions\" beräknar en rutt + restid mellan `from` och `to`; \"geocode\" omvandlar en adress till koordinater; \"reverse_geocode\" omvandlar `lat`/`lon` till en adress. För \"nära mig\" sätt `near` till \"me\" — detta använder enhetens plats OM användaren tillåtit det; annars söker verktyget utan platsbias, så fråga hellre användaren om en plats/område när platsen spelar roll. Använd \"locate\" först när användaren frågar var de är eller vad som finns i närheten och du inte känner till deras område. `from`/`to` för rutter kan vara platsnamn eller adresser (verktyget slår upp dem). `transport`: automobile (standard), walking eller transit."
          }
        }
      }
    },
    "tool.rag_search.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Søg i brugerens vedhæftede dokumentsamlinger efter passager, der er relevante for en forespørgsel. Returnerer uddrag med dokumentnavn, side/afsnit og en relevansscore. Brug det, når svaret kan findes i brugerens eget materiale."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search the user's attached document collections for passages relevant to a query. Returns chunks with document name, page/section, and a relevance score. Use whenever the answer might be in the user's own corpus."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Search the user's attached document collections for passages relevant to a query. Returns chunks with document name, page/section, and a relevance score. Use whenever the answer might be in the user's own corpus."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Søk i brukerens vedlagte dokumentsamlinger etter passasjer som er relevante for et søk. Returnerer utdrag med dokumentnavn, side/avsnitt og en relevansscore. Bruk dette når svaret kan finnes i brukerens eget materiale."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sök i användarens bifogade dokumentsamlingar efter avsnitt relevanta för en fråga. Returnerar utdrag med dokumentnamn, sida/avsnitt och en relevanspoäng. Använd när svaret kan finnas i användarens eget material."
          }
        }
      }
    },
    "tool.reminders.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Læs brugerens macOS-påmindelser og (når brugeren har tilladt påmindelsesændringer) FORESLÅ at oprette, ændre, slette eller fuldføre påmindelser. `action`: \"search\" læser påmindelser (med det samme); \"create\"/\"edit\"/\"delete\"/\"complete\" træder IKKE i kraft med det samme — de foreslås, og brugeren skal bekræfte hver ændring i appen først. Til edit/delete/complete angives `reminder_id` for en påmindelse, du har fundet via søgning. Forfaldsdato er valgfri: angiv `due` som `ÅÅÅÅ-MM-DDTHH:MM` for en tidsbestemt påmindelse eller `ÅÅÅÅ-MM-DD` for en dag uden et bestemt tidspunkt (brugerens lokale tid). VIGTIGT: et forfaldstidspunkt udløser IKKE en alarm i sig selv — hvis brugeren angiver et tidspunkt, så SPØRG, om de også vil have en alarm/notifikation på det tidspunkt, og sæt `add_alarm` derefter (antag det ikke). VIGTIGT om datoer: dagens dato OG ugedag står i samtalen; når brugeren nævner en ugedag eller en relativ dag (\"i morgen\", \"i næste uge\"), så beregn den nøjagtige dato omhyggeligt, og dobbelttjek ugedagen, før du foreslår. `priority`: 0 ingen, 1 høj, 5 mellem, 9 lav."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read the user's macOS Reminders and (when the user has allowed reminder changes) PROPOSE creating, editing, deleting, or completing reminders. `action`: \"search\" reads reminders (immediate); \"create\"/\"edit\"/\"delete\"/\"complete\" do NOT take effect immediately — they are proposed and the user must confirm each change in the app before it happens. For edit/delete/complete, pass the `reminder_id` of a reminder you found via search. A reminder's due date is optional: provide `due` as `YYYY-MM-DDTHH:MM` for a timed reminder or `YYYY-MM-DD` for a day with no specific time (the user's local time). IMPORTANT: a due time alone does NOT raise an alert — if the user sets a due time, ASK whether they also want an alert/notification at that time, then set `add_alarm` accordingly (do not assume). IMPORTANT for dates: today's date AND weekday are given in the conversation; when the user names a weekday or a relative day (\"tomorrow\", \"next week\"), compute the exact calendar date carefully and double-check the weekday before proposing. `priority`: 0 none, 1 high, 5 medium, 9 low."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Read the user's macOS Reminders and (when the user has allowed reminder changes) PROPOSE creating, editing, deleting, or completing reminders. `action`: \"search\" reads reminders (immediate); \"create\"/\"edit\"/\"delete\"/\"complete\" do NOT take effect immediately — they are proposed and the user must confirm each change in the app before it happens. For edit/delete/complete, pass the `reminder_id` of a reminder you found via search. A reminder's due date is optional: provide `due` as `YYYY-MM-DDTHH:MM` for a timed reminder or `YYYY-MM-DD` for a day with no specific time (the user's local time). IMPORTANT: a due time alone does NOT raise an alert — if the user sets a due time, ASK whether they also want an alert/notification at that time, then set `add_alarm` accordingly (do not assume). IMPORTANT for dates: today's date AND weekday are given in the conversation; when the user names a weekday or a relative day (\"tomorrow\", \"next week\"), compute the exact calendar date carefully and double-check the weekday before proposing. `priority`: 0 none, 1 high, 5 medium, 9 low."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Les brukerens macOS-påminnelser og (når brukeren har tillatt endringer i påminnelser) FORESLÅ å opprette, redigere, slette eller fullføre påminnelser. `action`: \"search\" leser påminnelser (umiddelbart); \"create\"/\"edit\"/\"delete\"/\"complete\" trer IKKE i kraft umiddelbart — de foreslås, og brukeren må bekrefte hver endring i appen før den skjer. For edit/delete/complete, send `reminder_id` for en påminnelse du fant via search. Forfallsdato er valgfri: oppgi `due` som `YYYY-MM-DDTHH:MM` for en tidfestet påminnelse eller `YYYY-MM-DD` for en dag uten bestemt klokkeslett (brukerens lokale tid). VIKTIG: et forfallstidspunkt alene utløser IKKE et varsel — hvis brukeren angir et tidspunkt, SPØR om de også vil ha et varsel på det tidspunktet, og sett `add_alarm` deretter (ikke anta). VIKTIG om datoer: dagens dato OG ukedag er oppgitt i samtalen; når brukeren nevner en ukedag eller en relativ dag («i morgen», «neste uke»), beregn den nøyaktige kalenderdatoen nøye og dobbeltsjekk ukedagen før du foreslår. `priority`: 0 ingen, 1 høy, 5 middels, 9 lav."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Läs användarens macOS-påminnelser och (när användaren tillåtit påminnelseändringar) FÖRESLÅ att skapa, ändra, ta bort eller slutföra påminnelser. `action`: \"search\" läser påminnelser (omedelbart); \"create\"/\"edit\"/\"delete\"/\"complete\" träder INTE i kraft direkt — de föreslås och användaren måste bekräfta varje ändring i appen först. För edit/delete/complete, ange `reminder_id` för en påminnelse du hittat via sökning. Förfallodatum är valfritt: ange `due` som `ÅÅÅÅ-MM-DDTHH:MM` för en tidsbestämd påminnelse eller `ÅÅÅÅ-MM-DD` för en dag utan särskild tid (användarens lokala tid). VIKTIGT: en förfallotid ger INTE ett larm i sig — om användaren anger en tid, FRÅGA om de även vill ha ett larm/avisering vid den tiden och sätt `add_alarm` därefter (anta inte). VIKTIGT om datum: dagens datum OCH veckodag finns i konversationen; när användaren nämner en veckodag eller en relativ dag (\"imorgon\", \"nästa vecka\"), beräkna exakt datum noggrant och dubbelkolla veckodagen innan du föreslår. `priority`: 0 ingen, 1 hög, 5 medel, 9 låg."
          }
        }
      }
    },
    "tool.web_fetch.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Hent en webside via en URL, og returnér sidens læsbare hovedtekst, titel, forfatter og uddrag. Brug det efter web_search, når du har brug for sidens indhold, ikke kun søgeuddraget."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetch a web page by URL and return its main readable text, title, byline, and excerpt. Use after web_search when you need the page contents, not just the search snippet."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetch a web page by URL and return its main readable text, title, byline, and excerpt. Use after web_search when you need the page contents, not just the search snippet."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hent en nettside via URL og returner hovedteksten i lesbar form, tittel, byline og utdrag. Bruk etter web_search når du trenger sideinnholdet, ikke bare søketreffet."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hämta en webbsida på en URL och returnera sidans läsbara huvudtext, titel, författare och utdrag. Använd efter web_search när du behöver sidans innehåll, inte bara sökutdraget."
          }
        }
      }
    },
    "tool.web_search.desc": {
      "extractionState": "manual",
      "localizations": {
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Søg på det offentlige web efter aktuel information. Returnerer titel/url/uddrag for de bedste resultater. Brug det, når svaret kan have ændret sig siden modellens træningsgrænse, eller når der ønskes en kilde."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Search the public web for current information. Returns title/url/snippet for the top matches. Use when the answer may have changed since the model's training cutoff or when a citation is wanted."
          }
        },
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Search the public web for current information. Returns title/url/snippet for the top matches. Use when the answer may have changed since the model's training cutoff or when a citation is wanted."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Søk på det åpne nettet etter oppdatert informasjon. Returnerer tittel/url/utdrag for de beste treffene. Bruk når svaret kan ha endret seg etter modellens treningsgrense, eller når en kildehenvisning er ønsket."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sök på det publika webben efter aktuell information. Returnerar titel/url/utdrag för de bästa träffarna. Använd när svaret kan ha ändrats sedan modellens träningsstopp eller när en källa önskas."
          }
        }
      }
    }
  },
  "version": "1.0"
